# danger labels


danger_label = {
    "low"    : "🟢 Not urgent  — keep checking,can contiue driving",
    "medium" : "🟡 Fix soon    — dont ignore,may continue driving",
    "high"   : "🔴 Fix NOW     — urgent need to fix,dont drive"
}



# the matching logic


def issue(inp):

    # clean up the text first
    user_text = inp.lower()

    best_match    = None
    highest_score = 0

    for each_problem in info:

        score = 0

        for clue_word in each_problem["words"]:
            if clue_word in user_text:
                score = score + 1

        # keep track of whichever problem scored highest
        if score > highest_score:
            highest_score = score
            best_match    = each_problem

    # only return a match if at least one word matched
    if highest_score > 0:
        return best_match
    else:
        return None



# print the answer nicely


def show_answer(matched_problem):
    print()
    print("─" * 45)
    print("DIAGNOSIS :", matched_problem["problem"])
    print("URGENCY   :", danger_label[ matched_problem["danger"] ])
    print("─" * 45)
    print("WHAT TO DO:")
    for tip in matched_problem["tips"]:
        print("  •", tip)
    print("─" * 45)
    print()



# simple responses for hello / thanks / bye


hello_words = ["hello", "hi", "hey", "namaste", "good morning", "good evening"]
thanks_words = ["thanks", "thank you", "thx", "helpful"]
bye_words   = ["bye", "exit", "quit", "goodbye", "done", "stop"]



# main chat loop — this is where everything runs


def start():

    print()
    print("=" * 45)
    print("   🔧  CAR DOCTOR — Diagnosis Chatbot")
    print("=" * 45)
    print("  Tell me your car problem in plain words.")
    print("  Example: 'my brakes are squeaking'")
    print("  Type  bye  to exit.")
    print("=" * 45)
    print()

    while True:

        user_input = input("You: ").strip()

        # skip if user typed nothing
        if user_input == "":
            continue

        clean_input = user_input.lower()

        # check for bye
        for word in bye_words:
            if word in clean_input:
                print("\nBot: Take care! Hope your car gets fixed soon. 👋\n")
                return

        # check for hello
        for word in hello_words:
            if word in clean_input:
                print("\nBot: Hey! Tell me what is wrong with your car. 🚗\n")
                break
        else:

            # check for thanks
            said_thanks = False
            for word in thanks_words:
                if word in clean_input:
                    print("\nBot: Happy to help! Drive safe. 😊\n")
                    said_thanks = True
                    break

            if not said_thanks:

                # actually try to diagnose the problem
                result = issue(user_input)

                if result:
                    show_answer(result)
                else:
                    print()
                    print("Bot: Hmm, I did not understand that.")
                    print("     Try saying something like:")
                    print("     → 'my car wont start'")
                    print("     → 'brakes are making noise'")
                    print("     → 'engine is overheating'")
                    print()


#run CarDoc
start()
